#include <stdio.h>
#include <string.h>

int main()
{
    char a[10];
    char b[] = "abc";

    // --- 第一部分：用 strcpy ---
    strcpy(a, b);
    printf("strcpy 结果: %s\n", a);

    // --- 第二部分：用 strncpy (对比) ---
    // 先把 a 清空
    memset(a, 0, sizeof(a)); 

    // 使用 strncpy，安全地拷贝
    strncpy(a, "hello_world", sizeof(a) - 1);
    a[sizeof(a) - 1] = '\0'; // 强制补一个结束符

    printf("strncpy 结果: %s\n", a);

    return 0;
}
